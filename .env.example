# Ocean.io — lookalike company search
OCEAN_IO_API_KEY=

# Prospeo — decision-maker search + email enrichment fallback
PROSPEO_API_KEY=

# EazyReach — LinkedIn to work email (optional; falls back to Prospeo enrich)
EAZYREACH_API_KEY=
EAZYREACH_BASE_URL=https://api.eazyreach.app

# Brevo — transactional email (use REST API key, NOT SMTP key)
BREVO_API_KEY=
SENDER_EMAIL=
SENDER_NAME=

# Pipeline limits
MAX_COMPANIES=20
MAX_CONTACTS_PER_COMPANY=3

# Resilience
RETRY_MAX_ATTEMPTS=5
LOG_LEVEL=INFO

# Storage
DATABASE_PATH=data/outreach.db
OUTPUT_DIR=outputs
LOG_DIR=logs
