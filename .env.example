# Ocean.io — lookalike company search
OCEAN_IO_API_KEY=

# Prospeo — decision-maker search (X-KEY) + email enrichment (X-API-KEY)
PROSPEO_API_KEY=

# Brevo — REST API key (xkeysib-...) or SMTP key (xsmtpsib-...)
BREVO_API_KEY=
# Required for SMTP keys (xsmtpsib-...) — copy from Brevo → SMTP & API → SMTP tab
# Looks like: add6ce001@smtp-brevo.com (NOT your personal email)
BREVO_SMTP_LOGIN=add6ce001@smtp-brevo.com
SENDER_EMAIL=rohit@divfixer.com
SENDER_NAME=Rohit | DivFixer

# Pipeline limits
SEED_DOMAIN=stripe.com
MAX_COMPANIES=10
MAX_CONTACTS_PER_COMPANY=3

# Resilience
RETRY_MAX_ATTEMPTS=5
LOG_LEVEL=INFO

# Storage
DATABASE_PATH=data/outreach.db
OUTPUT_DIR=outputs
LOG_DIR=logs
